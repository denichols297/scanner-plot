# Copy this file to .env and fill in your credentials
# Leave BROADCASTIFY credentials blank to run in Demo Mode

BROADCASTIFY_USERNAME=
BROADCASTIFY_PASSWORD=
BROADCASTIFY_FEED_ID=29700

# Whisper model size: tiny.en, base.en, small.en, medium.en
WHISPER_MODEL=base.en

# Set to true to force demo mode even with credentials
DEMO_MODE=false
